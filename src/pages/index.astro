---
import SEO from '../components/SEO.astro';
import Card from '../components/Card.astro';
import Grid from '../components/Grid.astro';

const categories = [
  { id: 'topic', name: '选题与策划', icon: '💡', desc: '爆款选题公式、情绪共鸣标签与科普结构脚本生成提示词。', path: '/wiki/topic', count: '5 个词条' },
  { id: 'narrative', name: '叙事与脚本', icon: '📝', desc: '传统三幕式、英雄之旅、黄金3秒强吸睛开场的脚本生成指令。', path: '/wiki/narrative', count: '5 个词条' },
  { id: 'framing', name: '分镜设计', icon: '🖼️', desc: '极特写、特写、俯瞰、仰角、POV主观分镜的景别提示词。', path: '/wiki/framing', count: '8 个词条' },
  { id: 'camera', name: '运镜控制', icon: '🎥', desc: '推拉摇移、360°环绕、希区柯克变焦等 AI 运镜 Prompt。', path: '/wiki/camera', count: '10 个词条' },
  { id: 'editing', name: '剪辑与后期', icon: '✂️', desc: '无缝物理转场、脸部闪烁修复、AI 局部重绘与丝滑补帧工作流。', path: '/wiki/editing', count: '6 个词条' },
  { id: 'voiceover', name: '配音与音效', icon: '🎙️', desc: '旁白播音提示词、声音克隆最佳实践、BGM 风格生成 Tag 库。', path: '/wiki/voiceover', count: '5 个词条' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <SEO />
  </head>
  <body>
    <div class="container">
      <!-- Header -->
      <header class="main-header">
        <div class="header-left">
          <a href="/" class="logo">
            <span class="logo-emoji">🎬</span>
            <span class="logo-text">AI Video Hints</span>
          </a>
          <nav class="header-nav">
            <a href="/wiki/topic" class="nav-link">选题</a>
            <a href="/wiki/narrative" class="nav-link">剧本</a>
            <a href="/wiki/framing" class="nav-link">分镜</a>
            <a href="/wiki/camera" class="nav-link">运镜</a>
            <a href="/wiki/editing" class="nav-link">剪辑</a>
            <a href="/wiki/voiceover" class="nav-link">配音</a>
          </nav>
        </div>
        <div class="header-right">
          <a href="https://github.com" target="_blank" class="github-btn" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
            GitHub
          </a>
        </div>
      </header>

      <!-- Hero Section -->
      <section class="hero">
        <h1 class="hero-title">AI 视频制作速查手册</h1>
        <p class="hero-subtitle">开源、轻量、高密度的 AI 视频创作词条与提示词百科</p>

        <!-- Big Search Bar -->
        <div class="search-container">
          <div class="search-box">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" id="home-search" placeholder="输入任意词条关键字搜索 (如: 推进、特写、三幕式)..." autocomplete="off" />
          </div>
          <div id="search-results" class="search-results-panel hidden"></div>
        </div>
      </section>

      <!-- Featured Prompts Section -->
      <section class="categories-section">
        <h2 class="section-title">常用热门词条</h2>
        <Grid>
          <Card 
            title="希区柯克变焦 (Dolly Zoom)" 
            desc="通过相反方向的推拉镜头与变焦形成强烈的空间扭曲感与角色内心紧张感。"
            kling="Dolly zoom, camera moves forward while zooming out, dramatic background compression, cinematic depth of field."
            runway="Camera: Dolly Zoom (Zoom Out while moving forward)"
            luma="dolly zoom out"
            preview="/assets/previews/cyberpunk_preview.jpg"
          >
            <ul>
              <li><strong>适用场景</strong>：发现惊人秘密、角色陷入极度震惊、高潮惊悚时刻。</li>
              <li><strong>技巧</strong>：确保背景有纵深物（如长廊、长街），视觉扭曲效果最明显。</li>
            </ul>
          </Card>

          <Card 
            title="无缝物理转场 (Seamless Transitions)" 
            desc="通过快甩镜头（Whip Pan）或高速动态模糊实现极其自然的画面过渡。"
            kling="Seamless whip pan transition, camera pans fast to the right, motion blur, cut to a new scene panning in from the left."
            runway="Camera: Pan Right fast, whip pan, high motion blur transition"
            preview="/assets/previews/cyberpunk_preview.jpg"
          >
            <ul>
              <li><strong>适用场景</strong>：空间连续移动、快节奏动作剪辑、场景无缝变换。</li>
              <li><strong>技巧</strong>：前镜头的出画方向与后镜头的入画方向必须一致，AI 生成衔接度最高。</li>
            </ul>
          </Card>

          <Card 
            title="黄金 3 秒强吸睛开头 (Hooks)" 
            desc="快速制造悬念与情绪反差，大幅提高短视频的完播率与转化率。"
            kling="用极度反常的动作或情绪冲突开头，例如：第一句旁白为：‘这是我这辈子做过最荒谬的决定...’"
            runway="以微观细节特写或急速镜头拉出开始，第一句旁白：‘千万别点开这个视频，除非你想...’"
            preview="/assets/previews/cyberpunk_preview.jpg"
          >
            <ul>
              <li><strong>适用场景</strong>：知识科普、故事解说、产品推介等视频的开头黄金阶段。</li>
              <li><strong>技巧</strong>：前3秒的视觉冲击力（强运镜/特写）与旁白声效（Hook）需要高度同步。</li>
            </ul>
          </Card>

          <Card 
            title="上帝视角/垂直俯瞰 (Bird's Eye View)" 
            desc="从垂直向下 90 度的俯视角度拍摄，展现角色的渺小、孤独或空间的对称构图。"
            kling="Top-down bird's-eye view, vertical camera facing straight down, symmetrical composition, cinematic scale."
            runway="Camera: Top-down vertical bird's-eye view, high altitude static shot"
            luma="bird's eye view, top-down"
            preview="/assets/previews/cyberpunk_preview.jpg"
          >
            <ul>
              <li><strong>适用场景</strong>：空旷城市街道、森林包围、沙滩海岸线、大场景对称构图。</li>
              <li><strong>技巧</strong>：可加入微弱的旋转或拉镜头以增加画面生动感。</li>
            </ul>
          </Card>
        </Grid>
      </section>

      <!-- Footer -->
      <footer class="main-footer">
        <p>AI Video Hints — 纯开源项目，遵循 MIT 协议</p>
        <p class="footer-links">
          <a href="https://github.com" target="_blank" rel="noopener noreferrer">在 GitHub 上参与共建</a>
        </p>
      </footer>
    </div>

    <!-- Script for home page instant search -->
    <script>
      const searchDb = [
        { key: "选题", name: "爆款黄金开头 (Hooks)", category: "选题与策划", url: "/wiki/topic#爆款黄金开头-hooks" },
        { key: "选题", name: "情绪驱动模式 (Emotional)", category: "选题与策划", url: "/wiki/topic#情绪驱动模式-emotional-drivers" },
        { key: "选题", name: "科普解说结构 (Educational)", category: "选题与策划", url: "/wiki/topic#科普解说结构-educational-outlines" },
        { key: "剧本", name: "三幕式结构 (Three-Act)", category: "叙事与脚本", url: "/wiki/narrative#三幕式结构-three-act-structure" },
        { key: "剧本", name: "英雄之旅模型 (Hero's Journey)", category: "叙事与脚本", url: "/wiki/narrative#英雄之旅模型-heros-journey" },
        { key: "分镜", name: "特写 (Close-Up - CU)", category: "分镜设计", url: "/wiki/framing#特写-close-up---cu" },
        { key: "分镜", name: "全景与远景 (Full / Establishing)", category: "分镜设计", url: "/wiki/framing#全景与远景-full--establishing-shot" },
        { key: "分镜", name: "俯瞰/上帝视角 (Bird's Eye View)", category: "分镜设计", url: "/wiki/framing#俯瞰上帝视角-birds-eye-view" },
        { key: "运镜", name: "推镜头 (Zoom In / Dolly In)", category: "运镜控制", url: "/wiki/camera#推镜头-zoom-in--dolly-in" },
        { key: "运镜", name: "拉镜头 (Zoom Out / Dolly Out)", category: "运镜控制", url: "/wiki/camera#拉镜头-zoom-out--dolly-out" },
        { key: "运镜", name: "摇镜头 (Pan)", category: "运镜控制", url: "/wiki/camera#摇镜头-pan---leftright" },
        { key: "运镜", name: "移镜头 (Track/Truck)", category: "运镜控制", url: "/wiki/camera#移镜头-tracktruck---leftright" },
        { key: "运镜", name: "环绕运镜 (Orbit)", category: "运镜控制", url: "/wiki/camera#环绕运镜-orbit---360" },
        { key: "运镜", name: "希区柯克变焦 (Dolly Zoom)", category: "运镜控制", url: "/wiki/camera#希区柯克变焦-dolly-zoom" },
        { key: "后期", name: "无缝物理转场 (Transitions)", category: "剪辑与后期", url: "/wiki/editing#无缝物理转场-seamless-transitions" },
        { key: "配音", name: "旁白播音提示词 (Narrator)", category: "配音与音效", url: "/wiki/voiceover#旁白播音提示词-narrator-prompts" },
      ];

      const searchInput = document.getElementById('home-search') as HTMLInputElement | null;
      const searchResults = document.getElementById('search-results');

      if (searchInput && searchResults) {
        searchInput.addEventListener('input', (e) => {
          const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
          if (!query) {
            searchResults.classList.add('hidden');
            return;
          }

          const matches = searchDb.filter(item => 
            item.name.toLowerCase().includes(query) || 
            item.category.toLowerCase().includes(query) ||
            item.key.toLowerCase().includes(query)
          );

          if (matches.length === 0) {
            searchResults.innerHTML = '<div class="no-result">未找到匹配词条</div>';
          } else {
            searchResults.innerHTML = matches.slice(0, 8).map(m => `
              <a href="${m.url}" class="search-result-item">
                <span class="result-name">${m.name}</span>
                <span class="result-cat">${m.category}</span>
              </a>
            `).join('');
          }

          searchResults.classList.remove('hidden');
        });

        // Hide search results when clicking outside
        document.addEventListener('click', (e) => {
          if (!searchInput.contains(e.target as Node) && !searchResults.contains(e.target as Node)) {
            searchResults.classList.add('hidden');
          }
        });
      }
    </script>
  </body>
</html>

<style>
  /* Base styles */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header */
  .main-header {
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid #e4e4e7;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-link {
    font-size: 0.8rem;
    font-weight: 500;
    color: #71717a;
    text-decoration: none;
    padding: 0.3rem 0.6rem;
    border-radius: 4px;
    transition: all 0.15s ease;
  }

  .nav-link:hover {
    color: #09090b;
    background-color: #f4f4f5;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
  }

  .logo-emoji {
    font-size: 1.3rem;
  }

  .logo-text {
    font-size: 1.1rem;
    font-weight: 700;
    color: #09090b;
    letter-spacing: -0.01em;
  }

  .github-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: transparent;
    border: 1px solid #e4e4e7;
    border-radius: 4px;
    padding: 0.4rem 0.8rem;
    color: #27272a;
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .github-btn:hover {
    background: #f4f4f5;
    border-color: #d4d4d8;
    color: #09090b;
  }

  /* Hero Section */
  .hero {
    padding: 6rem 0 5rem 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-title {
    font-size: 2.75rem;
    font-weight: 800;
    color: #09090b;
    margin: 0;
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 2rem;
    }
  }

  .hero-subtitle {
    font-size: 1rem;
    color: #71717a;
    margin: 0.75rem 0 2.5rem 0;
    max-width: 600px;
    line-height: 1.5;
  }

  /* Search Bar */
  .search-container {
    position: relative;
    width: 100%;
    max-width: 600px;
  }

  .search-box {
    display: flex;
    align-items: center;
    background: #ffffff;
    border: 1px solid #e4e4e7;
    border-radius: 6px;
    padding: 0.75rem 1.2rem;
    gap: 0.75rem;
    transition: border-color 0.15s ease;
  }

  .search-box:focus-within {
    border-color: #a1a1aa;
  }

  .search-icon {
    color: #71717a;
  }

  #home-search {
    width: 100%;
    background: transparent;
    border: none;
    outline: none;
    color: #09090b;
    font-size: 0.95rem;
    font-weight: 500;
  }

  #home-search::placeholder {
    color: #a1a1aa;
  }

  /* Search Results Panel */
  .search-results-panel {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: #ffffff;
    border: 1px solid #e4e4e7;
    border-radius: 6px;
    max-height: 350px;
    overflow-y: auto;
    z-index: 100;
    text-align: left;
  }

  .search-results-panel.hidden {
    display: none;
  }

  .search-result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1.2rem;
    text-decoration: none;
    color: #27272a;
    border-bottom: 1px solid #e4e4e7;
    transition: all 0.15s ease;
  }

  .search-result-item:hover {
    background: #f4f4f5;
    color: #09090b;
  }

  .result-name {
    font-size: 0.85rem;
    font-weight: 500;
  }

  .result-cat {
    font-size: 0.7rem;
    color: #71717a;
    background: #f4f4f5;
    border: 1px solid #e4e4e7;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
  }

  .no-result {
    padding: 1.2rem;
    font-size: 0.85rem;
    color: #71717a;
    text-align: center;
  }

  /* Categories Section */
  .categories-section {
    padding: 1rem 0 5rem 0;
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: #71717a;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .categories-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .categories-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  /* Category Card */
  .category-card {
    background: #ffffff;
    border: 1px solid #e4e4e7;
    border-radius: 6px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: border-color 0.15s ease;
  }

  .category-card:hover {
    border-color: #a1a1aa;
  }

  .card-content {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .cat-icon {
    font-size: 1.4rem;
  }

  .cat-count {
    font-size: 0.65rem;
    color: #71717a;
    background: #f4f4f5;
    border: 1px solid #e4e4e7;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .category-card h3 {
    margin: 0 0 0.4rem 0;
    font-size: 1.05rem;
    color: #09090b;
    font-weight: 600;
  }

  .category-card p {
    margin: 0 0 1.25rem 0;
    font-size: 0.8rem;
    color: #27272a;
    line-height: 1.4;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    color: #09090b;
    font-size: 0.75rem;
    font-weight: 600;
  }

  /* Footer */
  .main-footer {
    border-top: 1px solid #e4e4e7;
    padding: 3rem 0;
    text-align: center;
    font-size: 0.75rem;
    color: #71717a;
  }

  .main-footer p {
    margin: 0.25rem 0;
  }

  .footer-links a {
    color: #71717a;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-links a:hover {
    color: #09090b;
  }
</style>
