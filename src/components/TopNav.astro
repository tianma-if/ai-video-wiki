---
interface Category { id: string; label: string; short: string; }
interface Props { categories: Category[]; active?: string; }
const { categories, active } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-border/80 bg-background/85 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-[1440px] items-center gap-4 px-5 lg:px-8">
    <a href="/" class="group flex min-w-fit items-center gap-3" aria-label="返回首页">
      <span class="grid size-8 place-items-center rounded-lg bg-card text-sm font-black text-foreground shadow-sm ring-1 ring-border transition-transform group-hover:rotate-6">AV</span>
      <span class="hidden text-sm font-semibold tracking-tight sm:block">AI Video Hints</span>
    </a>

    <nav class="hidden flex-1 items-center justify-center gap-1 lg:flex" aria-label="一级导航">
      {categories.map((category) => (
        <a href={`/${category.id}`} class:list={["rounded-md px-3 py-2 text-sm font-medium transition-colors hover:bg-muted hover:text-foreground", active === category.id ? "bg-muted text-foreground" : "text-muted-foreground"]}>{category.short}</a>
      ))}
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <label class="hidden h-9 items-center gap-2 rounded-md border border-input bg-card/70 px-3 text-muted-foreground shadow-sm transition-colors focus-within:border-ring sm:flex">
        <span class="text-xs" aria-hidden="true">⌕</span>
        <input id="doc-search" class="w-28 bg-transparent text-xs text-foreground outline-none placeholder:text-muted-foreground" placeholder="搜索分类..." aria-label="搜索分类" />
      </label>
      <a class="hidden rounded-md px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:bg-muted hover:text-foreground sm:inline-flex" href="https://github.com/tianma-if/ai-video-hints" target="_blank" rel="noreferrer">GitHub ↗</a>
      <details class="relative lg:hidden">
        <summary class="cursor-pointer list-none rounded-md px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:bg-muted hover:text-foreground">菜单</summary>
        <div class="absolute right-0 z-50 mt-3 w-52 rounded-lg border border-border bg-card p-2 shadow-xl">
          {categories.map((category) => <a class="block rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:bg-muted hover:text-foreground" href={`/${category.id}`}>{category.label}</a>)}
        </div>
      </details>
    </div>
  </div>
</header>
