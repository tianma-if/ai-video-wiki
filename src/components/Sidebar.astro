---
interface Category { id: string; label: string; short: string; }
interface SubNavigation { label: string; href: string; }
interface Props { categories: Category[]; active?: string; currentSubNavigation: SubNavigation[]; }
const { categories, active, currentSubNavigation } = Astro.props;
const activeCategory = categories.find((category) => category.id === active);
---

<aside class="hidden lg:block">
  <div class="sticky top-24 rounded-xl border border-border/80 bg-card/55 p-3 shadow-sm">
    <div class="px-2 pb-3 text-[11px] font-semibold uppercase tracking-[.2em] text-muted-foreground">速查分类</div>
    <nav class="space-y-1" aria-label="文档分类">
      {categories.map((category) => (
        <a href={`/${category.id}`} class:list={["flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium transition-colors hover:bg-muted hover:text-foreground", active === category.id ? "bg-muted text-foreground" : "text-muted-foreground"]}>
          <span class:list={["size-1.5 rounded-full", active === category.id ? "bg-primary" : "bg-border"]}></span>
          {category.label}
        </a>
      ))}
    </nav>

    {activeCategory && currentSubNavigation.length > 0 && (
      <div class="mt-4 border-t border-border/80 pt-4">
        <div class="px-3 pb-2 text-[11px] font-semibold uppercase tracking-[.16em] text-muted-foreground">本页章节</div>
        <div class="ml-3 border-l border-border pl-3">
          {currentSubNavigation.map((item) => <a href={item.href} class="block rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:bg-muted hover:text-foreground">{item.label}</a>)}
        </div>
      </div>
    )}

    <div class="mt-6 rounded-lg border border-border/80 bg-background/70 p-3">
      <p class="text-xs font-semibold text-foreground">开源共建</p>
      <p class="mt-2 text-xs leading-5 text-muted-foreground">发现更好用的 Prompt？欢迎提交 PR，一起完善这份创作者词典。</p>
      <a href="https://github.com/tianma-if/ai-video-hints" target="_blank" rel="noreferrer" class="mt-3 inline-block text-xs text-foreground underline decoration-border underline-offset-4 hover:text-primary">贡献内容 ↗</a>
    </div>
  </div>
</aside>
