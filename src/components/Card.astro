---
interface Props {
  title: string;
  desc?: string;
  kling?: string;
  runway?: string;
  luma?: string;
  midjourney?: string;
  sd?: string;
  preview?: string;
  previewStatic?: string;
}

const { title, desc, kling, runway, luma, midjourney, sd, preview, previewStatic } = Astro.props;

// SVG placeholder for static images
const defaultStatic = `data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="300" height="170" viewBox="0 0 300 170"><rect width="100%" height="100%" fill="%23141414"/><text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" fill="%23333333" font-family="sans-serif" font-size="12" font-weight="bold">AI VIDEO PREVIEW</text></svg>`;
---

<div class="wiki-card" data-preview={preview} data-static={previewStatic || defaultStatic}>
  <div class="card-header">
    <h3>{title}</h3>
    {desc && <p class="desc">{desc}</p>}
  </div>
  
  {preview && (
    <div class="media-preview">
      <div class="play-indicator">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
        <span>Hover to preview</span>
      </div>
      <img 
        src={previewStatic || defaultStatic} 
        data-animated={preview}
        data-static={previewStatic || defaultStatic}
        alt={title}
        class="preview-img"
        loading="lazy"
      />
    </div>
  )}

  <div class="prompts-list">
    {kling && (
      <div class="prompt-item">
        <div class="prompt-label">Kling</div>
        <div class="prompt-value-wrapper">
          <code class="prompt-text">{kling}</code>
          <button class="copy-btn" data-text={kling} title="Copy Kling Prompt">
            <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          </button>
        </div>
      </div>
    )}
    
    {runway && (
      <div class="prompt-item">
        <div class="prompt-label">Runway</div>
        <div class="prompt-value-wrapper">
          <code class="prompt-text">{runway}</code>
          <button class="copy-btn" data-text={runway} title="Copy Runway Prompt">
            <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          </button>
        </div>
      </div>
    )}

    {luma && (
      <div class="prompt-item">
        <div class="prompt-label">Luma</div>
        <div class="prompt-value-wrapper">
          <code class="prompt-text">{luma}</code>
          <button class="copy-btn" data-text={luma} title="Copy Luma Prompt">
            <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          </button>
        </div>
      </div>
    )}

    {midjourney && (
      <div class="prompt-item">
        <div class="prompt-label">Midjourney / SD</div>
        <div class="prompt-value-wrapper">
          <code class="prompt-text">{midjourney}</code>
          <button class="copy-btn" data-text={midjourney} title="Copy Midjourney Prompt">
            <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          </button>
        </div>
      </div>
    )}
    
    {sd && (
      <div class="prompt-item">
        <div class="prompt-label">Prompt Modifiers</div>
        <div class="prompt-value-wrapper">
          <code class="prompt-text">{sd}</code>
          <button class="copy-btn" data-text={sd} title="Copy Prompt Modifier">
            <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
          </button>
        </div>
      </div>
    )}
  </div>

  <div class="slot-content">
    <slot />
  </div>
</div>

<script>
  // Setup interactive hover images and clipboards when DOM loads
  const setupCards = () => {
    // Media preview hover effects
    const cards = document.querySelectorAll('.wiki-card');
    cards.forEach(card => {
      const img = card.querySelector('.preview-img') as HTMLImageElement | null;
      const playIndicator = card.querySelector('.play-indicator');
      if (!img) return;
      
      const animatedSrc = img.getAttribute('data-animated');
      const staticSrc = img.getAttribute('data-static');
      
      if (animatedSrc) {
        card.addEventListener('mouseenter', () => {
          img.src = animatedSrc;
          if (playIndicator) playIndicator.classList.add('playing');
        });
        card.addEventListener('mouseleave', () => {
          if (staticSrc) img.src = staticSrc;
          if (playIndicator) playIndicator.classList.remove('playing');
        });
      }
    });

    // Copy to clipboard logic
    const copyButtons = document.querySelectorAll('.copy-btn');
    copyButtons.forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const text = btn.getAttribute('data-text');
        if (!text) return;
        
        try {
          await navigator.clipboard.writeText(text);
          
          const originalHTML = btn.innerHTML;
          btn.innerHTML = '<span class="copied-text">Copied!</span>';
          btn.classList.add('copied');
          
          setTimeout(() => {
            btn.innerHTML = originalHTML;
            btn.classList.remove('copied');
          }, 1500);
        } catch (err) {
          console.error('Failed to copy prompt:', err);
        }
      });
    });
  };

  // Run on load and after Astro page transitions
  setupCards();
  document.addEventListener('astro:after-swap', setupCards);
</script>

<style>
  .wiki-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.15s ease;
  }

  .wiki-card:hover {
    border-color: var(--text-muted); /* Simple border highlight */
  }

  .card-header h3 {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .desc {
    margin: 0.25rem 0 0 0;
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  /* Media Preview Box */
  .media-preview {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 4px;
    overflow: hidden;
    background: var(--bg-base);
    border: 1px solid var(--border-color);
  }

  .preview-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .play-indicator {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 500;
    z-index: 5;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  .play-indicator.playing {
    opacity: 0;
  }

  /* Prompts list details */
  .prompts-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .prompt-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .prompt-label {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prompt-value-wrapper {
    display: flex;
    align-items: center;
    background: var(--bg-base);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 0.4rem 0.6rem;
    gap: 0.4rem;
    height: 2.2rem;
  }

  .prompt-text {
    flex: 1;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    color: var(--text-primary);
    font-size: 0.75rem;
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: none;
  }

  .prompt-text::-webkit-scrollbar {
    display: none;
  }

  .copy-btn {
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s ease;
    flex-shrink: 0;
  }

  .copy-btn:hover {
    color: var(--text-primary);
    background: var(--border-color);
  }

  .copy-btn.copied {
    color: #10b981;
    background: rgba(16, 185, 129, 0.08);
  }

  .copied-text {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0 2px;
  }

  /* Slot content styling (custom notes/tips inside MDX) */
  .slot-content {
    font-size: 0.75rem;
    color: var(--text-secondary);
    line-height: 1.4;
    border-top: 1px solid var(--border-color);
    padding-top: 0.6rem;
    margin-top: 0.2rem;
  }

  .slot-content :global(ul) {
    margin: 0;
    padding-left: 1rem;
  }

  .slot-content :global(li) {
    margin-bottom: 0.2rem;
  }

  .slot-content :global(strong) {
    color: var(--text-primary);
  }
</style>
