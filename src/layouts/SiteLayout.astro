---
import SEO from '../components/SEO.astro';
import '../styles/custom.css';

interface Props { title?: string; description?: string; active?: string; }
const { title, description, active } = Astro.props;
const categories = [
  { id: 'topic', label: '选题与策划', short: '选题' },
  { id: 'narrative', label: '叙事与脚本', short: '叙事' },
  { id: 'framing', label: '分镜设计', short: '分镜' },
  { id: 'camera', label: '运镜控制', short: '运镜' },
  { id: 'editing', label: '剪辑与后期', short: '剪辑' },
  { id: 'voiceover', label: '配音与音效', short: '声音' },
];
const subNavigation: Record<string, { label: string; href: string }[]> = {
  topic: [{ label: '选题与策划机制', href: '#topic-overview' }],
  narrative: [{ label: '经典剧本结构', href: '#narrative-overview' }],
  framing: [{ label: '景别与构图', href: '#framing-overview' }],
  camera: [
    { label: '基础运镜', href: '#camera-basic' },
    { label: '创意运镜', href: '#camera-creative' },
  ],
  editing: [{ label: '后期与剪辑优化', href: '#editing-overview' }],
  voiceover: [{ label: '声音与音轨设计', href: '#voiceover-overview' }],
};
const currentSubNavigation = active ? subNavigation[active] ?? [] : [];
---
<!doctype html>
<html lang="zh-CN" data-theme="light">
  <head><SEO title={title} description={description} /></head>
  <body>
    <header class="sticky top-0 z-40 border-b border-zinc-900/10 bg-[#f7f7f5]/85 backdrop-blur-xl">
      <div class="mx-auto flex h-16 max-w-[1440px] items-center gap-4 px-5 lg:px-8">
        <a href="/" class="group flex min-w-fit items-center gap-3" aria-label="返回首页">
          <span class="grid size-8 place-items-center rounded-lg bg-white text-sm font-black text-black transition-transform group-hover:rotate-6">AV</span>
          <span class="hidden text-sm font-semibold tracking-tight sm:block">AI Video Hints</span>
        </a>
          <nav class="hidden flex-1 items-center justify-center gap-1 lg:flex" aria-label="一级导航">
            {categories.map((category) => (
            <a href={`/${category.id}`} class:list={["rounded-lg px-4 py-2 text-sm transition-colors hover:bg-zinc-900/5 hover:text-zinc-900", active === category.id ? "bg-zinc-900/10 text-zinc-900" : "text-zinc-500"]}>{category.short}</a>
          ))}
        </nav>
        <div class="ml-auto flex items-center gap-2">
          <label class="hidden items-center gap-2 rounded-lg border border-zinc-900/10 bg-white/70 px-3 py-2 text-zinc-500 focus-within:border-zinc-900/25 sm:flex">
            <span class="text-xs">⌕</span><input id="doc-search" class="w-28 bg-transparent text-xs text-zinc-900 outline-none placeholder:text-zinc-400" placeholder="搜索分类..." aria-label="搜索分类" />
          </label>
          <a class="btn btn-ghost btn-sm hidden text-zinc-500 hover:text-zinc-900 sm:inline-flex" href="https://github.com/tianma-if/ai-video-hints" target="_blank" rel="noreferrer">GitHub ↗</a>
          <div class="dropdown dropdown-end lg:hidden">
            <button class="btn btn-ghost btn-sm" aria-label="打开导航">菜单</button>
            <ul class="menu dropdown-content z-50 mt-3 w-52 rounded-box border border-zinc-900/10 bg-white p-2 shadow-2xl">
              {categories.map((category) => <li><a href={`/${category.id}`}>{category.label}</a></li>)}
            </ul>
          </div>
        </div>
      </div>
    </header>
    <main class="mx-auto grid max-w-[1440px] grid-cols-1 gap-10 px-5 py-10 lg:grid-cols-[220px_minmax(0,1fr)] lg:px-8">
      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <p class="mb-4 px-3 text-[11px] font-semibold uppercase tracking-[.2em] text-zinc-600">速查分类</p>
          <nav class="space-y-5" aria-label="二级导航">
            {active && <div>
              <a href={`/${active}`} class="mb-3 flex items-center gap-2 px-3 text-sm font-semibold text-zinc-900">
                <span class="size-1.5 rounded-full bg-zinc-900"></span>
                {categories.find((category) => category.id === active)?.label}
              </a>
              <div class="ml-3 border-l border-zinc-900/10 pl-3">
                {currentSubNavigation.map((item) => <a href={item.href} class="block rounded-lg px-3 py-2 text-sm text-zinc-500 transition hover:bg-zinc-900/5 hover:text-zinc-900">{item.label}</a>)}
              </div>
            </div>}
            {!active && <div class="rounded-xl border border-zinc-900/10 bg-white/60 p-3 text-xs leading-5 text-zinc-500">选择顶部一级导航，查看该栏目下的章节。</div>}
          </nav>
          <div class="mt-10 rounded-2xl border border-zinc-900/10 bg-white/60 p-4">
            <p class="text-xs font-semibold text-zinc-800">开源共建</p>
            <p class="mt-2 text-xs leading-5 text-zinc-500">发现更好用的 Prompt？欢迎提交 PR，一起完善这份创作者词典。</p>
            <a href="https://github.com/tianma-if/ai-video-hints" target="_blank" rel="noreferrer" class="mt-3 inline-block text-xs text-zinc-700 underline decoration-zinc-900/20 underline-offset-4 hover:text-zinc-950">贡献内容 ↗</a>
          </div>
        </div>
      </aside>
      <div class="min-w-0"><slot /></div>
    </main>
    <footer class="mx-auto flex max-w-[1440px] items-center justify-between border-t border-zinc-900/10 px-5 py-8 text-xs text-zinc-500 lg:px-8"><span>AI Video Hints · 开源提示词速查</span><span>Built with Astro</span></footer>
    <script>
      const search = document.querySelector('#doc-search');
      search?.addEventListener('input', (event) => {
        const value = event.target.value.toLowerCase().trim();
        document.querySelectorAll('nav[aria-label="文档分类"] a').forEach((link) => {
          link.classList.toggle('hidden', value !== '' && !link.textContent.toLowerCase().includes(value));
        });
      });
    </script>
  </body>
</html>
