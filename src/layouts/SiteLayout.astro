---
import SEO from '../components/SEO.astro';
import TopNav from '../components/TopNav.astro';
import Sidebar from '../components/Sidebar.astro';
import '../styles/custom.css';

interface Props { title?: string; description?: string; active?: string; }
const { title, description, active } = Astro.props;
const categories = [
  { id: 'topic', label: '选题与策划', short: '选题' },
  { id: 'narrative', label: '叙事与脚本', short: '叙事' },
  { id: 'framing', label: '分镜设计', short: '分镜' },
  { id: 'camera', label: '运镜控制', short: '运镜' },
  { id: 'editing', label: '剪辑与后期', short: '剪辑' },
  { id: 'voiceover', label: '配音与音效', short: '声音' },
];
const subNavigation: Record<string, { label: string; href: string }[]> = {
  topic: [{ label: '选题与策划机制', href: '#topic-overview' }],
  narrative: [{ label: '经典剧本结构', href: '#narrative-overview' }],
  framing: [{ label: '景别与构图', href: '#framing-overview' }],
  camera: [
    { label: '基础运镜', href: '#camera-basic' },
    { label: '创意运镜', href: '#camera-creative' },
  ],
  editing: [{ label: '后期与剪辑优化', href: '#editing-overview' }],
  voiceover: [{ label: '声音与音轨设计', href: '#voiceover-overview' }],
};
const currentSubNavigation = active ? subNavigation[active] ?? [] : [];
---
<!doctype html>
<html lang="zh-CN">
  <head><SEO title={title} description={description} /></head>
  <body>
    <TopNav categories={categories} active={active} />
    <main class="mx-auto grid max-w-[1440px] grid-cols-1 gap-10 px-5 py-10 lg:grid-cols-[220px_minmax(0,1fr)] lg:px-8">
      <Sidebar categories={categories} active={active} currentSubNavigation={currentSubNavigation} />
      <div class="min-w-0"><slot /></div>
    </main>
    <footer class="mx-auto flex max-w-[1440px] items-center justify-between border-t border-zinc-900/10 px-5 py-8 text-xs text-zinc-500 lg:px-8"><span>AI Video Hints · 开源提示词速查</span><span>Built with Astro</span></footer>
    <script>
      const search = document.querySelector('#doc-search');
      search?.addEventListener('input', (event) => {
        const value = event.target.value.toLowerCase().trim();
        document.querySelectorAll('nav[aria-label="文档分类"] a').forEach((link) => {
          link.classList.toggle('hidden', value !== '' && !link.textContent.toLowerCase().includes(value));
        });
      });
    </script>
  </body>
</html>
