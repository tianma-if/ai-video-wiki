---
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, headings = [] } = Astro.props;

// List of all categories for sidebar navigation
const categories = [
  { id: 'topic', name: '选题与策划', shortName: '选题', path: '/wiki/topic' },
  { id: 'narrative', name: '叙事与脚本', shortName: '剧本', path: '/wiki/narrative' },
  { id: 'framing', name: '分镜设计', shortName: '分镜', path: '/wiki/framing' },
  { id: 'camera', name: '运镜控制', shortName: '运镜', path: '/wiki/camera' },
  { id: 'editing', name: '剪辑与后期', shortName: '剪辑', path: '/wiki/editing' },
  { id: 'voiceover', name: '配音与音效', shortName: '配音', path: '/wiki/voiceover' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <SEO title={title} description={description} />
  </head>
  <body>
    <div class="app-container">
      <!-- Main Top Header -->
      <header class="main-header">
        <div class="header-left">
          <a href="/" class="logo">
            <span class="logo-emoji">🎬</span>
            <span class="logo-text">AI Video Hints</span>
            <span class="logo-badge">开源速查</span>
          </a>
          <nav class="header-nav">
            {categories.map(cat => (
              <a 
                href={cat.path} 
                class={`nav-link ${currentPath.includes(cat.path) ? 'active' : ''}`}
              >
                {cat.shortName}
              </a>
            ))}
          </nav>
        </div>
        <div class="header-center">
          <div class="search-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" id="global-search" placeholder="输入关键字快速检索词条 (e.g. 运镜, 推镜头)..." autocomplete="off" />
            <div id="search-results" class="search-results-dropdown hidden"></div>
          </div>
        </div>
        <div class="header-right">
          <a href="https://github.com" target="_blank" class="github-link" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
            <span>GitHub</span>
          </a>
        </div>
      </header>

      <!-- Main Layout Body -->
      <div class="layout-main">
        <!-- Sidebar Left (TOC of current page headings as Level 2/3 nav) -->
        <aside class="sidebar-left">
          <div class="sidebar-title">本类目录</div>
          <nav class="category-nav">
            {headings && headings.filter(h => h.depth === 2 || h.depth === 3).length > 0 ? (
              headings.filter(h => h.depth === 2 || h.depth === 3).map(h => {
                return (
                  <a href={`#${h.slug}`} class={`nav-item depth-${h.depth}`}>
                    <span class="bullet"></span>
                    <span class="nav-text">{h.text}</span>
                  </a>
                );
              })
            ) : (
              <span class="no-subheadings">暂无子类目录</span>
            )}
          </nav>
        </aside>

        <!-- Center Content Area -->
        <main class="content-wrapper">
          <div class="content-header">
            <h1 class="page-title">{title}</h1>
            {description && <p class="page-desc">{description}</p>}
          </div>
          <article class="markdown-body">
            <slot />
          </article>
        </main>
      </div>
    </div>

    <!-- Client-side Interactive Script -->
    <script>
      // Quick search database for MVP
      const searchDb = [
        { key: "选题", name: "爆款黄金开头 (Hooks)", category: "选题与策划", url: "/wiki/topic#爆款黄金开头-hooks" },
        { key: "选题", name: "情绪驱动模式 (Emotional)", category: "选题与策划", url: "/wiki/topic#情绪驱动模式-emotional-drivers" },
        { key: "选题", name: "科普解说结构 (Educational)", category: "选题与策划", url: "/wiki/topic#科普解说结构-educational-outlines" },
        { key: "剧本", name: "三幕式结构 (Three-Act)", category: "叙事与脚本", url: "/wiki/narrative#三幕式结构-three-act-structure" },
        { key: "剧本", name: "英雄之旅模型 (Hero's Journey)", category: "叙事与脚本", url: "/wiki/narrative#英雄之旅模型-heros-journey" },
        { key: "分镜", name: "特写 (Close-Up - CU)", category: "分镜设计", url: "/wiki/framing#特写-close-up---cu" },
        { key: "分镜", name: "景别", category: "分镜设计", url: "/wiki/framing" },
        { key: "运镜", name: "推镜头 (Zoom In / Dolly In)", category: "运镜控制", url: "/wiki/camera#推镜头-zoom-in--dolly-in" },
        { key: "运镜", name: "拉镜头 (Zoom Out / Dolly Out)", category: "运镜控制", url: "/wiki/camera#拉镜头-zoom-out--dolly-out" },
        { key: "运镜", name: "摇镜头 (Pan)", category: "运镜控制", url: "/wiki/camera#摇镜头-pan---leftright" },
        { key: "运镜", name: "移镜头 (Track/Truck)", category: "运镜控制", url: "/wiki/camera#移镜头-tracktruck---leftright" },
        { key: "运镜", name: "环绕运镜 (Orbit)", category: "运镜控制", url: "/wiki/camera#环绕运镜-orbit---360" },
        { key: "运镜", name: "希区柯克变焦 (Dolly Zoom)", category: "运镜控制", url: "/wiki/camera#希区柯克变焦-dolly-zoom" },
        { key: "后期", name: "无缝物理转场 (Transitions)", category: "剪辑与后期", url: "/wiki/editing#无缝物理转场-seamless-transitions" },
        { key: "配音", name: "旁白播音提示词 (Narrator)", category: "配音与音效", url: "/wiki/voiceover#旁白播音提示词-narrator-prompts" },
      ];

      const searchInput = document.getElementById('global-search') as HTMLInputElement | null;
      const searchResults = document.getElementById('search-results');

      if (searchInput && searchResults) {
        searchInput.addEventListener('input', (e) => {
          const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
          if (!query) {
            searchResults.classList.add('hidden');
            return;
          }

          const matches = searchDb.filter(item => 
            item.name.toLowerCase().includes(query) || 
            item.category.toLowerCase().includes(query) ||
            item.key.toLowerCase().includes(query)
          );

          if (matches.length === 0) {
            searchResults.innerHTML = '<div class="no-result">未找到匹配词条</div>';
          } else {
            searchResults.innerHTML = matches.slice(0, 8).map(m => `
              <a href="${m.url}" class="search-result-item">
                <div class="result-name">${m.name}</div>
                <div class="result-cat">${m.category}</div>
              </a>
            `).join('');
          }

          searchResults.classList.remove('hidden');
        });

        // Hide search results when clicking outside
        document.addEventListener('click', (e) => {
          if (!searchInput.contains(e.target as Node) && !searchResults.contains(e.target as Node)) {
            searchResults.classList.add('hidden');
          }
        });
      }

      // Scroll Spy for left sidebar secondary/tertiary navigation headings
      const headingElements = Array.from(document.querySelectorAll('.markdown-body h2, .markdown-body h3'));
      const sidebarLinks = Array.from(document.querySelectorAll('.sidebar-left .nav-item'));

      if (headingElements.length > 0 && sidebarLinks.length > 0) {
        const updateActiveSidebar = () => {
          let activeHeading = null;
          const scrollPos = window.scrollY || document.documentElement.scrollTop;

          // Find the heading that is currently scrolled past the threshold (e.g. 100px from top)
          for (const heading of headingElements) {
            const top = (heading as HTMLElement).offsetTop - 100;
            if (scrollPos >= top) {
              activeHeading = heading;
            } else {
              break;
            }
          }

          if (activeHeading) {
            const activeId = activeHeading.getAttribute('id');
            sidebarLinks.forEach(link => {
              const href = link.getAttribute('href');
              if (href === `#${activeId}`) {
                link.classList.add('active');
              } else {
                link.classList.remove('active');
              }
            });
          } else {
            // Default to highlight the first heading if at the very top
            sidebarLinks.forEach((link, idx) => {
              if (idx === 0) link.classList.add('active');
              else link.classList.remove('active');
            });
          }
        };

        window.addEventListener('scroll', updateActiveSidebar);
        updateActiveSidebar(); // Initialize active state on load
      }
    </script>
  </body>
</html>

<style is:global>
  /* Global CSS Variables & Base resets */
  :root {
    --bg-base: #fafafa;
    --bg-surface: #ffffff;
    --bg-header: rgba(255, 255, 255, 0.9);
    --border-color: #e4e4e7;
    --text-primary: #09090b;
    --text-secondary: #27272a;
    --text-muted: #71717a;
    --accent: #09090b;
    --accent-rgb: 9, 9, 11;
    --font-sans: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  html {
    scroll-behavior: smooth;
    background-color: var(--bg-base);
    color: var(--text-primary);
    font-family: var(--font-sans);
    overflow-y: scroll;
  }

  body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    position: relative;
  }
</style>

<style>
  /* Local styles for layout elements */
  .app-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* Header Styles */
  .main-header {
    height: 56px;
    background-color: var(--bg-header);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-link {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.3rem 0.6rem;
    border-radius: 4px;
    transition: all 0.15s ease;
  }

  .nav-link:hover {
    color: var(--text-primary);
    background-color: var(--border-color);
  }

  .nav-link.active {
    color: var(--text-primary);
    background-color: var(--border-color);
    font-weight: 600;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .logo-emoji {
    font-size: 1.1rem;
  }

  .logo-text {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .logo-badge {
    font-size: 0.65rem;
    color: var(--text-secondary);
    background: transparent;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    border: 1px solid var(--border-color);
    font-weight: 600;
  }

  /* Header Search Bar */
  .search-wrapper {
    position: relative;
    width: 320px;
  }

  .search-icon {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }

  #global-search {
    width: 100%;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 0.4rem 1rem 0.4rem 2.2rem;
    color: var(--text-primary);
    font-size: 0.8rem;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.15s ease;
  }

  #global-search:focus {
    border-color: var(--text-muted);
  }

  /* Search Results Dropdown */
  .search-results-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    max-height: 300px;
    overflow-y: auto;
    z-index: 200;
  }

  .search-results-dropdown.hidden {
    display: none;
  }

  .search-result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 0.85rem;
    text-decoration: none;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-color);
    transition: background 0.15s ease;
  }

  .search-result-item:hover {
    background: var(--bg-base);
    color: var(--text-primary);
  }

  .result-name {
    font-size: 0.8rem;
    font-weight: 500;
  }

  .result-cat {
    font-size: 0.7rem;
    color: var(--text-muted);
    background: var(--bg-base);
    border: 1px solid var(--border-color);
    padding: 0.05rem 0.3rem;
    border-radius: 3px;
  }

  .no-result {
    padding: 0.85rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-align: center;
  }

  .github-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    transition: color 0.15s ease;
  }

  .github-link:hover {
    color: #ffffff;
  }

  /* Main Layout Structure */
  .layout-main {
    flex: 1;
    display: flex;
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  /* Left Sidebar Categories */
  .sidebar-left {
    width: 200px;
    border-right: 1px solid var(--border-color);
    padding: 2rem 1rem;
    position: sticky;
    top: 56px;
    height: calc(100vh - 56px);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sidebar-title {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding-left: 0.5rem;
  }

  .category-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 0.75rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    border-radius: 4px;
    transition: all 0.15s ease;
  }

  .nav-item .bullet {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: transparent;
    transition: background 0.15s ease;
  }

  .nav-item:hover {
    background: var(--border-color);
    color: var(--text-primary);
  }

  .nav-item.active {
    background: var(--border-color);
    color: var(--text-primary);
  }

  .nav-item.active .bullet {
    background: var(--text-primary);
  }

  .nav-item.depth-2 {
    font-weight: 600;
    color: var(--text-primary);
  }

  .nav-item.depth-3 {
    padding-left: 1.5rem;
    font-size: 0.75rem;
  }

  .no-subheadings {
    padding: 0.5rem 0.75rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* Center Content Area */
  .content-wrapper {
    flex: 1;
    min-width: 0;
    padding: 2.5rem 2.5rem 4rem 2.5rem;
    box-sizing: border-box;
  }

  .content-header {
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
  }

  .page-title {
    margin: 0;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .page-desc {
    margin: 0.4rem 0 0 0;
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.45;
  }

  .markdown-body :global(h2) {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.4rem;
    scroll-margin-top: 72px; /* Offset for sticky header */
  }

  .markdown-body :global(h3) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Right TOC Sidebar */
  .sidebar-right {
    width: 220px;
    border-left: 1px solid var(--border-color);
    padding: 2rem 1.2rem;
    position: sticky;
    top: 56px;
    height: calc(100vh - 56px);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .toc-title {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    overflow-y: auto;
  }

  .toc-item {
    font-size: 0.7rem;
    line-height: 1.3;
  }

  .toc-item a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .toc-item a:hover {
    color: var(--text-primary);
  }

  .toc-item.depth-2 {
    font-weight: 600;
    margin-top: 0.3rem;
    color: var(--text-primary);
  }

  .toc-item.depth-3 {
    padding-left: 0.75rem;
    border-left: 1px solid var(--border-color);
  }

  /* Responsive styling */
  @media (max-width: 1024px) {
    .sidebar-right {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .layout-main {
      flex-direction: column;
    }

    .sidebar-left {
      width: 100%;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--border-color);
      padding: 0.6rem 1rem;
      position: sticky;
      top: 56px;
      z-index: 90;
      background-color: var(--bg-base);
    }

    .sidebar-title {
      display: none;
    }

    .category-nav {
      flex-direction: row;
      overflow-x: auto;
      scrollbar-width: none;
      gap: 0.2rem;
      padding-bottom: 0.2rem;
    }

    .category-nav::-webkit-scrollbar {
      display: none;
    }

    .nav-item {
      white-space: nowrap;
      padding: 0.35rem 0.5rem;
      font-size: 0.75rem;
    }

    .content-wrapper {
      padding: 1.5rem 1rem;
    }

    .search-wrapper {
      width: 200px;
    }

    .logo-text, .github-link span {
      display: none;
    }
  }
</style>
